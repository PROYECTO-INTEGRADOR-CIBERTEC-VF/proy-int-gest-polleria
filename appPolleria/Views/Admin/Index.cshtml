@{
    ViewBag.Title = "Panel Administrador";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Panel Administrador</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #FDF6F0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #fff;
            border-radius: 14px;
            padding: 2.5rem 2rem;
            text-align: center;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
            max-width: 400px;
            width: 100%;
        }

        .badge {
            background: #B85C38;
            color: #fff;
            border-radius: 20px;
            padding: 4px 16px;
            font-size: 13px;
            display: inline-block;
            margin-bottom: 1rem;
        }

        h1 {
            font-size: 22px;
            color: #1a1a1a;
            margin-bottom: 0.5rem;
        }

        p {
            color: #888;
            font-size: 14px;
            margin-bottom: 1.5rem;
        }

        a {
            color: #B85C38;
            font-size: 13px;
            text-decoration: none;
        }

            a:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <div class="card">
        <span class="badge">Administrador</span>
        <h1>Bienvenido, @ViewBag.Usuario</h1>
        <p>Has iniciado sesión correctamente como administrador.</p>
        <a href="/Home/Logout">Cerrar sesión</a>
    </div>
</body>
</html>