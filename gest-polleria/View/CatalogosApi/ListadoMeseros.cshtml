@model IEnumerable<gest_polleria.Models.Mesero>

@{
    ViewData["Title"] = "Catálogo de Meseros";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-people-fill"></i> Catálogo de Meseros</h2>
        <a asp-action="RegistrarMesero" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Mesero
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre Completo</th>
                        <th>DNI</th>
                        <th>Teléfono</th>
                        <th class="text-center">Turno</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.IdMesero</td>
                                <td>@item.Nombre @item.Apellido</td>
                                <td>@item.DNI</td>
                                <td>@item.Telefono</td>
                                <td class="text-center">
                                    <span class="badge @(item.Turno == "Mañana" ? "bg-info" : item.Turno == "Tarde" ? "bg-warning" : "bg-dark")">
                                        @item.Turno
                                    </span>
                                </td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="text-success"><i class="bi bi-check-circle"></i> Activo</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger"><i class="bi bi-x-circle"></i> Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">No hay meseros registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>