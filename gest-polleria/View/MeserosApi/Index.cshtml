@model IEnumerable<gest_polleria.Models.Mesero>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-person-badge"></i> Catálogo de Meseros</h2>
        <div>
            <a asp-action="RegistrarMesero" class="btn btn-danger">
                <i class="bi bi-plus-circle"></i> Nuevo Mesero
            </a>
            <a asp-action="AsignarMeseroMesa" class="btn btn-warning">
                <i class="bi bi-geo-alt"></i> Asignar Mesa
            </a>
        </div>
    </div>
    <hr />

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    <table class="table table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre Completo</th>
                <th>DNI</th>
                <th>Teléfono</th>
                <th>Turno</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdMesero</td>
                    <td>@item.Nombre @item.Apellido</td>
                    <td>@item.DNI</td>
                    <td>@item.Telefono</td>
                    <td><span class="badge bg-info text-dark">@item.Turno</span></td>
                    <td>
                        @if (item.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {

                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>