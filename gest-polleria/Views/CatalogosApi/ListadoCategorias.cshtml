@model IEnumerable<appPolleria.Models.CategoriaProducto>

@{
    ViewData["Title"] = "Categorías de Productos";
    ViewBag.Titulo = "Gestión de Catálogos";
}

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
        --bg-light: #f4f7f6;
    }

    .btn-system-red {
        background-color: var(--primary-red);
        color: white;
        border: none;
        transition: all 0.3s;
        font-weight: 600;
        border-radius: 8px;
    }

        .btn-system-red:hover {
            background-color: #c0392b;
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(231, 76, 60, 0.2);
        }

    .table-thead-custom {
        background-color: #f8f9fa;
        border-bottom: 2px solid var(--primary-red);
    }

    .badge-category {
        background-color: rgba(243, 156, 18, 0.1);
        color: #d35400;
        font-weight: 700;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        border: 1px solid rgba(243, 156, 18, 0.2);
    }
</style>

<div class="layout" style="display: flex; height: 100vh; width: 100%; background-color: var(--bg-light);">

    @await Html.PartialAsync("~/Views/Dashboard/_Sidebar.cshtml")

    <div class="content" style="flex: 1; display: flex; flex-direction: column; height: 100%;">

        @await Html.PartialAsync("~/Views/Dashboard/_Header.cshtml")

        <div class="main-content" style="flex: 1; overflow-y: auto; padding: 2rem;">

            <div class="mb-4 text-center">
                <div style="background-color: var(--primary-red); width: 60px; height: 60px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; box-shadow: 0 4px 10px rgba(231, 76, 60, 0.3);">
                    <i class="fa-solid fa-layer-group fa-2x" style="color: white;"></i>
                </div>
                <h2 style="font-weight: 800; color: var(--dark-blue); text-transform: uppercase; letter-spacing: 1px;">Categorías de Productos</h2>
                <div style="width: 50px; height: 4px; background: var(--primary-red); margin: 0.5rem auto; border-radius: 2px;"></div>
            </div>

            <div class="d-flex justify-content-end mb-3">
                <a asp-action="RegistrarCategoria" class="btn btn-system-red shadow-sm" style="padding: 0.6rem 1.2rem;">
                    <i class="fa-solid fa-plus-circle me-2"></i> Nueva Categoría
                </a>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-thead-custom">
                                <tr>
                                    <th class="py-3 px-4" style="width: 15%">Código</th>
                                    <th class="py-3" style="width: 25%">Categoría</th>
                                    <th class="py-3" style="width: 45%">Descripción</th>
                                    <th class="py-3 text-center" style="width: 15%">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="px-4">
                                                <span class="fw-bold text-muted">#@item.IdCategoria</span>
                                            </td>
                                            <td>
                                                <span class="badge-category text-uppercase">@item.Nombre</span>
                                            </td>
                                            <td>
                                                <p class="mb-0 text-muted small" style="max-width: 400px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    @item.Descripcion
                                                </p>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group shadow-sm" style="border-radius: 8px; overflow: hidden;">
                                                    <a href="#" class="btn btn-sm btn-outline-dark border-0" title="Editar" style="background-color: rgba(52, 152, 219, 0.1);">
                                                        <i class="fa-solid fa-pen-to-square text-primary"></i>
                                                    </a>
                                                    <a href="#" class="btn btn-sm btn-outline-dark border-0" title="Eliminar" style="background-color: rgba(231, 76, 60, 0.1);">
                                                        <i class="fa-solid fa-trash-can text-danger"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5">
                                            <i class="fa-solid fa-folder-open fa-3x text-muted mb-3 opacity-25"></i>
                                            <p class="text-muted">No hay categorías registradas en el catálogo.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>