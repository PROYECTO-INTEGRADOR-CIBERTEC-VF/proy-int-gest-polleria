@model appPolleria.Models.CategoriaProducto

@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-tags me-2"></i> Registrar Nueva Categoría</h5>
                </div>
                <div class="card-body bg-light">
                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-info shadow-sm">@ViewBag.Mensaje</div>
                    }
                    <form asp-action="RegistrarCategoria" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre de Categoría</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Pollos a la Brasa" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold">Descripción (Opcional)</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger w-100 shadow">Guardar Categoría</button>
                            <a asp-action="ListadoCategorias" class="btn btn-secondary w-100">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>