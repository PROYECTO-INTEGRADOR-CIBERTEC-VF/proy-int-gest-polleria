@model appPolleria.Models.Cliente

@{
    ViewData["Title"] = "Registro de Nuevo Cliente";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-user-plus me-2"></i> Nuevo Cliente para la Familia</h4>
                </div>
                <div class="card-body p-4 bg-light">

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
                            <i class="fas fa-info-circle me-2"></i> @ViewBag.Mensaje
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="RegistrarCliente" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold text-muted">Tipo de Cliente</label>
                                <div class="form-check form-switch p-0 ms-4">
                                    <input class="form-check-input" type="checkbox" id="checkEsEmpresa" asp-for="EsEmpresa" style="transform: scale(1.5);">
                                    <label class="form-check-label ms-3" for="checkEsEmpresa">Es una Empresa / Negocio</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="TipoDocumento" class="form-label fw-bold">Tipo Doc.</label>
                                <select asp-for="TipoDocumento" class="form-select border-danger-subtle shadow-sm">
                                    <option value="DNI">DNI</option>
                                    <option value="RUC">RUC</option>
                                    <option value="CE">C. Extranjería</option>
                                </select>
                            </div>

                            <div class="col-md-8">
                                <label asp-for="NumeroDocumento" class="form-label fw-bold">Número de Documento</label>
                                <input asp-for="NumeroDocumento" class="form-control border-danger-subtle shadow-sm" placeholder="Ej: 77123456" required />
                                <span asp-validation-for="NumeroDocumento" class="text-danger small"></span>
                            </div>

                            <div id="sectionPersona" class="row col-12 g-3 m-0 p-0">
                                <div class="col-md-6">
                                    <label asp-for="Nombres" class="form-label fw-bold">Nombres</label>
                                    <input asp-for="Nombres" class="form-control shadow-sm" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Apellidos" class="form-label fw-bold">Apellidos</label>
                                    <input asp-for="Apellidos" class="form-control shadow-sm" />
                                </div>
                            </div>

                            <div id="sectionEmpresa" class="col-md-12 d-none">
                                <label asp-for="RazonSocial" class="form-label fw-bold text-danger">Razón Social de la Empresa</label>
                                <input asp-for="RazonSocial" class="form-control border-danger shadow-sm text-uppercase" />
                            </div>

                            <div class="col-md-12 mt-4 mb-2">
                                <hr class="text-muted">
                                <h6 class="text-muted text-uppercase fw-bold"><i class="fas fa-map-marker-alt me-2"></i>Ubicación y Contacto</h6>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Direccion" class="form-label fw-bold">Dirección de Entrega / Fiscal</label>
                                <input asp-for="Direccion" class="form-control shadow-sm" placeholder="Av. Los Laureles 123..." />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Telefono" class="form-label fw-bold">Teléfono / WhatsApp</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fab fa-whatsapp"></i></span>
                                    <input asp-for="Telefono" class="form-control shadow-sm" placeholder="987654321" />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold">Correo Electrónico</label>
                                <input asp-for="Email" type="email" class="form-control shadow-sm" placeholder="ejemplo@correo.com" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-5">
                            <a asp-action="ListadoClientes" class="btn btn-outline-secondary px-4">
                                Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger px-5 fw-bold shadow">
                                <i class="fas fa-save me-2"></i> Guardar Cliente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            $("#checkEsEmpresa").change(function () {
                if ($(this).is(":checked")) {
                    $("#sectionPersona").addClass("d-none");
                    $("#sectionEmpresa").removeClass("d-none");
                    $("#TipoDocumento").val("RUC");
                } else {
                    $("#sectionPersona").removeClass("d-none");
                    $("#sectionEmpresa").addClass("d-none");
                    $("#TipoDocumento").val("DNI");
                }
            });
        });
    </script>
}