@{
    ViewData["Title"] = "Panel de Control";
}

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
        --bg-pure-white: #ffffff;
    }

    body {
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-color: var(--bg-pure-white);
    }

    .dashboard-layout {
        display: flex;
        height: 100vh;
        width: 100vw;
        background-color: var(--bg-pure-white);
    }

    .main-viewport {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    /* AJUSTE: Padding derecho aumentado a 12rem para empujar todo a la izquierda */
    .dashboard-content {
        flex: 1;
        overflow-y: auto;
        padding: 100px 12rem 3rem 1.5rem;
        background-color: var(--bg-pure-white);
    }

    .header-welcome {
        text-align: left;
        margin-bottom: 2.5rem;
    }

        .header-welcome h1 {
            font-weight: 800;
            color: var(--dark-blue);
            font-size: 2.4rem;
            margin: 0;
            margin-bottom: 0.5rem;
        }

    .group-title {
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #adb5bd;
        letter-spacing: 1.5px;
        margin: 2.5rem 0 1.5rem 0;
        display: flex;
        align-items: center;
        justify-content: flex-start;
    }

        .group-title::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #f1f3f5;
            margin-left: 1.5rem;
            max-width: 60%; /* Se acorta la línea para que el bloque se vea más compacto a la izquierda */
        }

    .grid-menu {
        display: grid;
        /* Se ajustó el minmax a 240px para que las tarjetas sean ligeramente más pequeñas y quepan mejor a la izquierda */
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.5rem;
        justify-content: start;
    }

    .menu-card {
        background: white;
        border-radius: 20px;
        padding: 2.2rem 1.2rem;
        text-align: center;
        text-decoration: none;
        color: var(--dark-blue);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 1px solid #f8f9fa;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

        .menu-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(231, 76, 60, 0.1);
            border-color: var(--primary-red);
            color: var(--primary-red) !important;
        }

    .icon-container {
        width: 65px;
        height: 65px;
        background-color: #fcfcfc;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 1.2rem;
        color: var(--dark-blue);
        transition: all 0.3s ease;
    }

    .menu-card:hover .icon-container {
        background-color: var(--primary-red);
        color: white;
    }

    .menu-card h3 {
        font-size: 1.1rem;
        font-weight: 800;
        margin: 0;
    }

    .menu-card p {
        font-size: 0.85rem;
        color: #94a3b8;
        margin-top: 0.5rem;
        line-height: 1.3;
    }
</style>

<div class="dashboard-layout">

    @await Html.PartialAsync("~/Views/Dashboard/_Sidebar.cshtml")

    <div class="main-viewport">

        @await Html.PartialAsync("~/Views/Dashboard/_Header.cshtml")

        <div class="dashboard-content">
            <div class="header-welcome">
                <h1>Bienvenido al <span style="color: var(--primary-red);">Pollería System</span></h1>
                <p class="text-muted fs-5">Panel de administración centralizada.</p>
            </div>

            @* Operaciones *@
            <div class="group-title">Operaciones Diarias</div>
            <div class="grid-menu">
                <a asp-controller="Mesa" asp-action="Mesa" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-table"></i></div>
                    <h3>Gestión de Mesas</h3>
                    <p>Atención de salón y ocupación.</p>
                </a>
                <a asp-controller="Pedidos" asp-action="Pedido" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-receipt"></i></div>
                    <h3>Pedidos</h3>
                    <p>Comandas y facturación rápida.</p>
                </a>
                <a asp-controller="Compras" asp-action="Compra" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-cart-shopping"></i></div>
                    <h3>Compras</h3>
                    <p>Ingreso de mercadería y gastos.</p>
                </a>
                <a asp-controller="ProductosApi" asp-action="ListadoProductosCarta" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-box"></i></div>
                    <h3>Productos</h3>
                    <p>Platos, combos y precios.</p>
                </a>
            </div>

            @* Producción *@
            <div class="group-title">Inventario y Producción</div>
            <div class="grid-menu">
                <a asp-controller="InsumosApi" asp-action="ListadoInsumos" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-apple-whole"></i></div>
                    <h3>Insumos</h3>
                    <p>Stock detallado de materia prima.</p>
                </a>
                <a asp-controller="ProductosInsumosApi" asp-action="ListadoRecetaProducto" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-kitchen-set"></i></div>
                    <h3>Recetas</h3>
                    <p>Fichas técnicas y costos.</p>
                </a>
            </div>

            @* Administración *@
            <div class="group-title">Administración y Maestros</div>
            <div class="grid-menu">
                <a asp-controller="ClientesApi" asp-action="ListadoClientes" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-address-book"></i></div>
                    <h3>Clientes</h3>
                    <p>Registro de personas y empresas.</p>
                </a>
                <a asp-controller="Proveedor" asp-action="Proveedor" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-truck-field"></i></div>
                    <h3>Proveedores</h3>
                    <p>Gestión de abastecimiento.</p>
                </a>
                <a asp-controller="CatalogosApi" asp-action="ListadoCategorias" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-layer-group"></i></div>
                    <h3>Categorías</h3>
                    <p>Organización del menú.</p>
                </a>
                <a asp-controller="CatalogosApi" asp-action="ListadoRoles" class="menu-card">
                    <div class="icon-container"><i class="fa-solid fa-user-gear"></i></div>
                    <h3>Roles</h3>
                    <p>Seguridad y perfiles de acceso.</p>
                </a>
            </div>
        </div>
    </div>
</div>