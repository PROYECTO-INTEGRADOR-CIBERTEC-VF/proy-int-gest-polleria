@model appPolleria.Models.Mesa

@{
    ViewData["Title"] = "Actualizar Mesa";
    ViewBag.Titulo = "Gestión de Salón";
}

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
        --bg-light: #f4f7f6;
    }

    /* Estilos para el switch personalizado con el color del sistema */
    .form-check-input:checked {
        background-color: var(--primary-red) !important;
        border-color: var(--primary-red) !important;
    }

    /* Enfoque de los inputs con el color rojo */
    .form-control:focus {
        border-color: var(--primary-red);
        box-shadow: 0 0 0 0.25rem rgba(231, 76, 60, 0.25);
    }
</style>

<div class="layout" style="display: flex; height: 100vh; width: 100%; background-color: var(--bg-light);">

    @await Html.PartialAsync("~/Views/Dashboard/_Sidebar.cshtml")

    <div class="content" style="flex: 1; display: flex; flex-direction: column; height: 100%;">

        @await Html.PartialAsync("~/Views/Dashboard/_Header.cshtml")

        <div class="main-content" style="flex: 1; overflow-y: auto; padding: 3rem; display: flex; justify-content: center; align-items: flex-start;">

            <div class="card shadow-lg" style="width: 100%; max-width: 500px; border: none; border-radius: 15px;">

                <div class="card-header text-white text-center" style="background-color: var(--primary-red); border-radius: 15px 15px 0 0; padding: 1.5rem; border: none;">
                    <i class="fa-solid fa-pen-to-square fa-2x mb-2"></i>
                    <h3 class="mb-0" style="font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Actualizar Mesa</h3>
                    <div style="width: 40px; height: 3px; background: white; margin: 0.5rem auto; border-radius: 2px; opacity: 0.7;"></div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Actualizar" method="post">
                        <input type="hidden" asp-for="IdMesa" />

                        <div class="mb-3">
                            <label asp-for="NumeroMesa" class="form-label fw-bold" style="color: var(--dark-blue);">N° de Mesa</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white" style="border-right: none;">
                                    <i class="fa-solid fa-hashtag" style="color: var(--primary-red);"></i>
                                </span>
                                <input asp-for="NumeroMesa" class="form-control" style="border-left: none; border-radius: 0 8px 8px 0;" />
                            </div>
                            <span asp-validation-for="NumeroMesa" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold" style="color: var(--dark-blue);">Descripción</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white" style="border-right: none;">
                                    <i class="fa-solid fa-align-left" style="color: var(--primary-red);"></i>
                                </span>
                                <input asp-for="Descripcion" class="form-control" style="border-left: none; border-radius: 0 8px 8px 0;" />
                            </div>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Capacidad" class="form-label fw-bold" style="color: var(--dark-blue);">Capacidad</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white" style="border-right: none;">
                                    <i class="fa-solid fa-users" style="color: var(--primary-red);"></i>
                                </span>
                                <input asp-for="Capacidad" class="form-control" type="number" style="border-left: none; border-radius: 0 8px 8px 0;" />
                            </div>
                            <span asp-validation-for="Capacidad" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold d-block" style="color: var(--dark-blue);">Estado de Disponibilidad</label>
                            <div class="form-check form-switch p-3 border rounded shadow-sm bg-light" style="display: flex; align-items: center; justify-content: space-between;">
                                <label class="form-check-label fw-bold" for="switchEstado" style="margin-left: 0.5rem; color: var(--dark-blue);">
                                    @(Model.Activa ? "ACTIVA" : "INACTIVA")
                                </label>
                                <input asp-for="Activa" class="form-check-input" type="checkbox" role="switch" id="switchEstado" style="width: 2.5em; height: 1.25em; cursor: pointer;">
                            </div>
                        </div>

                        <div class="d-grid gap-2 pt-2">
                            <button type="submit" class="btn btn-lg shadow" style="background-color: var(--primary-red); color: white; border: none; border-radius: 10px; font-weight: 700;">
                                <i class="fa-solid fa-circle-check me-2"></i> GUARDAR CAMBIOS
                            </button>
                            <a asp-action="Mesa" class="btn btn-link text-decoration-none fw-bold" style="color: var(--dark-blue); font-size: 0.9rem;">
                                <i class="fa-solid fa-chevron-left me-1"></i> VOLVER AL LISTADO
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}