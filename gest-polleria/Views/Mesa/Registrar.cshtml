@model appPolleria.Models.Mesa

@{
    ViewData["Title"] = "Registrar Mesa";
    ViewBag.Titulo = "Gestión de Salón";
}

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
        --bg-light: #f4f7f6;
    }

    /* Enfoque de los inputs con el color del sistema */
    .form-control:focus {
        border-color: var(--primary-red);
        box-shadow: 0 0 0 0.25rem rgba(231, 76, 60, 0.25);
    }

    .input-group-text {
        background-color: #ffffff;
        border-right: none;
    }

    .form-control {
        border-left: none;
        border-radius: 0 8px 8px 0;
    }
</style>

<div class="layout" style="display: flex; height: 100vh; width: 100%; background-color: var(--bg-light);">

    @await Html.PartialAsync("~/Views/Dashboard/_Sidebar.cshtml")

    <div class="content" style="flex: 1; display: flex; flex-direction: column; height: 100%;">

        @await Html.PartialAsync("~/Views/Dashboard/_Header.cshtml")

        <div class="main-content" style="flex: 1; overflow-y: auto; padding: 3rem; display: flex; justify-content: center; align-items: flex-start;">

            <div class="card shadow-lg" style="width: 100%; max-width: 500px; border: none; border-radius: 15px;">

                <div class="card-header text-white text-center" style="background-color: var(--primary-red); border-radius: 15px 15px 0 0; padding: 2rem; border: none;">
                    <i class="fa-solid fa-circle-plus fa-3x mb-3"></i>
                    <h3 class="mb-0" style="font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Nueva Mesa</h3>
                    <div style="width: 40px; height: 3px; background: white; margin: 0.5rem auto; border-radius: 2px; opacity: 0.7;"></div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Registrar" method="post">

                        <div class="mb-3">
                            <label asp-for="NumeroMesa" class="form-label fw-bold" style="color: var(--dark-blue);">N° de Mesa</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text"><i class="fa-solid fa-hashtag" style="color: var(--primary-red);"></i></span>
                                <input asp-for="NumeroMesa" class="form-control" placeholder="Ej: 15" />
                            </div>
                            <span asp-validation-for="NumeroMesa" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold" style="color: var(--dark-blue);">Descripción / Ubicación</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text"><i class="fa-solid fa-map-location-dot" style="color: var(--primary-red);"></i></span>
                                <input asp-for="Descripcion" class="form-control" placeholder="Ej: Terraza, Ventana..." />
                            </div>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Capacidad" class="form-label fw-bold" style="color: var(--dark-blue);">Capacidad (Personas)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text"><i class="fa-solid fa-users" style="color: var(--primary-red);"></i></span>
                                <input asp-for="Capacidad" class="form-control" type="number" min="1" placeholder="Ej: 4" />
                            </div>
                            <span asp-validation-for="Capacidad" class="text-danger small"></span>
                        </div>

                        <input type="hidden" asp-for="Activa" value="true" />

                        <hr class="my-4" style="opacity: 0.1;">

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-lg shadow" style="background-color: var(--primary-red); color: white; border: none; border-radius: 12px; font-weight: 700; padding: 0.8rem;">
                                <i class="fa-solid fa-floppy-disk me-2"></i> GUARDAR MESA
                            </button>
                            <a asp-action="Mesa" class="btn btn-link text-decoration-none fw-bold" style="color: var(--dark-blue);">
                                <i class="fa-solid fa-arrow-left me-1"></i> VOLVER AL LISTADO
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}