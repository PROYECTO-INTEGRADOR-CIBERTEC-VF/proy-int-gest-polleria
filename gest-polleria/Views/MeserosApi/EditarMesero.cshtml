@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model gest_polleria.Models.Mesero

@{
    ViewData["Title"] = "Editar Mesero";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
        --bg-light: #f4f7f6;
    }

    body {
        background-color: var(--bg-light);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .main-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 90vh;
        padding: 2rem;
    }

    .central-container {
        width: 100%;
        max-width: 750px; /* Un poco más ancho para mejor alineación */
    }

    .glass-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        padding: 3rem;
    }

    .form-label {
        font-weight: 700;
        color: var(--dark-blue);
        margin-bottom: 0.4rem;
        font-size: 0.9rem;
    }

    .form-control-custom {
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        height: 45px;
        padding: 0 1.2rem;
        transition: all 0.3s ease;
        background-color: #fcfcfc;
    }

        .form-control-custom:focus {
            border-color: var(--primary-red);
            box-shadow: 0 0 0 4px rgba(231, 76, 60, 0.1);
            background-color: #fff;
            outline: none;
        }

    /* Estilo para campos que no se deben editar */
    .form-control-readonly {
        background-color: #f1f3f5 !important;
        cursor: not-allowed;
        color: #6c757d;
    }

    .btn-save {
        background-color: var(--primary-red);
        color: white;
        border-radius: 10px;
        font-weight: 700;
        padding: 0 2rem;
        height: 50px;
        border: none;
        transition: all 0.2s;
        cursor: pointer;
    }

        .btn-save:hover {
            background-color: #c0392b;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(231, 76, 60, 0.3);
        }

    .btn-cancel {
        background-color: #bdc3c7;
        color: white;
        border-radius: 10px;
        font-weight: 700;
        padding: 0 2rem;
        height: 50px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s;
    }

        .btn-cancel:hover {
            background-color: #95a5a6;
            color: white;
        }
</style>

<div class="main-wrapper">
    <div class="central-container">

        <div class="title-section text-center mb-4">
            <h1>EDITAR <span style="color: var(--primary-red);">MESERO</span></h1>
            <div style="width: 60px; height: 4px; background: var(--primary-red); margin: 0 auto; border-radius: 2px;"></div>
        </div>

        <div class="glass-card">

            @* --- MENSAJE DE ERROR DEL SERVIDOR --- *@
            @if (ViewBag.MensajeError != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert" style="border-radius: 12px;">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Atención:</strong> @ViewBag.MensajeError
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="EditarMesero" method="post">
                <input type="hidden" asp-for="IdMesero" />

                <div class="row">
                    @* Fila 1: Nombre y Apellido *@
                    <div class="col-md-6 mb-3">
                        <label asp-for="Nombre" class="form-label">Nombre</label>
                        <input asp-for="Nombre" class="form-control form-control-custom" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Apellido" class="form-label">Apellido</label>
                        <input asp-for="Apellido" class="form-control form-control-custom" />
                    </div>
                </div>

                <div class="row">
                    @* Fila 2: DNI y Teléfono *@
                    <div class="col-md-6 mb-3">
                        <label asp-for="DNI" class="form-label">DNI / Documento</label>
                        <input asp-for="DNI" class="form-control form-control-custom" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefono" class="form-label">Teléfono</label>
                        <input asp-for="Telefono" class="form-control form-control-custom" placeholder="Ej: 999 999 999" />
                    </div>
                </div>

                <div class="row">
                    @* Fila 3: Turno y Estado (Alineados) *@
                    <div class="col-md-6 mb-3">
                        <label asp-for="Turno" class="form-label">Turno Asignado</label>
                        <select asp-for="Turno" class="form-select form-control-custom">
                            <option value="Mañana">Mañana</option>
                            <option value="Tarde">Tarde</option>
                            <option value="Noche">Noche</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="Activo" type="checkbox" class="form-check-input me-2" id="checkActivo" style="width: 20px; height: 20px; cursor: pointer;">
                            <label class="form-check-label fw-bold" for="checkActivo" style="cursor: pointer; color: #555;">
                                Mesero Activo
                            </label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" style="opacity: 0.1;">

                <div class="d-flex justify-content-center gap-3">
                    <button type="submit" class="btn btn-save">
                        <i class="fa fa-save me-2"></i>Guardar Cambios
                    </button>

                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fa fa-times me-2"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>