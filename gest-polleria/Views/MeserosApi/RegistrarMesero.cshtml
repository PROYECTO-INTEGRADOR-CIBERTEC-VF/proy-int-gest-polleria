@model gest_polleria.Models.Mesero

@{
    ViewData["Title"] = "Nuevo Mesero";
    ViewBag.Titulo = "Registro de Personal";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
        --bg-light: #f4f7f6;
    }

    body {
        background-color: var(--bg-light);
    }

    .central-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
    }

    .glass-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 2.5rem;
    }

    .form-label {
        font-weight: 700;
        color: var(--dark-blue);
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-control-custom {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        height: 45px;
        transition: 0.3s;
    }

        .form-control-custom:focus {
            border-color: var(--primary-red);
            box-shadow: 0 0 0 0.2rem rgba(231, 76, 60, 0.1);
        }

    .btn-save {
        background-color: var(--primary-red);
        color: white;
        border-radius: 8px;
        font-weight: 600;
        padding: 12px 30px;
        border: none;
        transition: 0.3s;
    }

        .btn-save:hover {
            background-color: #c0392b;
            transform: translateY(-1px);
            color: white;
        }

    .btn-back {
        background-color: #95a5a6;
        color: white;
        border-radius: 8px;
        padding: 12px 30px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            background-color: #7f8c8d;
            color: white;
        }
</style>

<div class="layout" style="display: flex; min-height: 100vh;">
    @await Html.PartialAsync("~/Views/Dashboard/_Sidebar.cshtml")

    <div class="content" style="flex: 1; display: flex; flex-direction: column;">
        @await Html.PartialAsync("~/Views/Dashboard/_Header.cshtml")

        <main class="central-container">
            @* Encabezado *@
            <div class="text-center mb-4">
                <div style="background: var(--primary-red); width: 50px; height: 50px; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px;">
                    <i class="fa fa-user-plus text-white"></i>
                </div>
                <h2 style="font-weight: 800; color: #2c3e50;">REGISTRAR <span style="color: var(--primary-red);">NUEVO MESERO</span></h2>
            </div>

            @if (ViewBag.MensajeError != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="fa fa-exclamation-circle me-2"></i> @ViewBag.MensajeError
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="glass-card">
                <form asp-action="RegistrarMesero" method="post">
                    <div class="row g-3">
                        @* DNI *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Número de DNI</label>
                            <input asp-for="DNI" class="form-control form-control-custom" placeholder="Ingrese 8 dígitos" required maxlength="8" />
                        </div>

                        @* Teléfono *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Teléfono / Celular</label>
                            <input asp-for="Telefono" class="form-control form-control-custom" placeholder="999 999 999" required />
                        </div>

                        @* Nombres *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombres</label>
                            <input asp-for="Nombre" class="form-control form-control-custom" placeholder="Nombres completos" required />
                        </div>

                        @* Apellidos *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Apellidos</label>
                            <input asp-for="Apellido" class="form-control form-control-custom" placeholder="Apellidos completos" required />
                        </div>

                        @* Turno *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Turno de Trabajo</label>
                            <select asp-for="Turno" class="form-select form-control-custom" required>
                                <option value="">Seleccione un turno...</option>
                                <option value="Mañana">Mañana</option>
                                <option value="Tarde">Tarde</option>
                                <option value="Noche">Noche</option>
                            </select>
                        </div>

                        @* Estado *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Estado Inicial</label>
                            <div class="form-check form-switch pt-2">
                                <input class="form-check-input" type="checkbox" asp-for="Activo" checked>
                                <label class="form-check-label text-muted">Mesero Activo</label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" style="opacity: 0.1;">

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-back">
                            <i class="fa fa-arrow-left me-2"></i>Cancelar
                        </a>
                        <button type="submit" class="btn btn-save">
                            <i class="fa fa-save me-2"></i>Guardar Registro
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</div>