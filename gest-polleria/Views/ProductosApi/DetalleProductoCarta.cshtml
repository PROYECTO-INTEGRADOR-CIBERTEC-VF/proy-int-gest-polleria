@model appPolleria.Models.Producto

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-search-plus me-2 text-warning"></i> Ficha del Producto</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4 border-bottom pb-3">
                        <div class="col-sm-4 text-muted fw-bold">Nombre del Plato:</div>
                        <div class="col-sm-8 fs-4 fw-bold text-danger">@Model.Nombre</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Categoría:</div>
                        <div class="col-sm-8 fw-bold">@Model.IdCategoria</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Precio de Venta:</div>
                        <div class="col-sm-8 text-success fw-bold">S/ @Model.PrecioVenta.ToString("N2")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">¿Es un Combo?:</div>
                        <div class="col-sm-8">@(Model.EsCombo ? "SÍ" : "NO")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Estado Actual:</div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.Activo ? "bg-success" : "bg-danger")">
                                @(Model.Activo ? "ACTIVO EN CARTA" : "FUERA DE SERVICIO")
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light d-flex justify-content-end gap-2 py-3">
                    <a asp-action="ListadoProductosCarta" class="btn btn-outline-secondary">Volver</a>
                    <a asp-action="EdicionProductoCarta" asp-route-id="@Model.IdProducto" class="btn btn-primary">Editar Datos</a>
                </div>
            </div>
        </div>
    </div>
</div>