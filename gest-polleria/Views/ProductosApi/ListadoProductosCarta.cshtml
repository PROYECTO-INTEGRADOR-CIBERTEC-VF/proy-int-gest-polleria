@model IEnumerable<appPolleria.Models.Producto>

@{
    ViewData["Title"] = "Carta de Productos";
    ViewBag.Titulo = "Gestión de Carta";
}

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
    }

    .btn-system-red {
        background-color: var(--primary-red);
        color: white;
        border: none;
        transition: all 0.3s;
    }

        .btn-system-red:hover {
            background-color: #c0392b;
            color: white;
            transform: translateY(-1px);
        }

    .table-thead-custom {
        background-color: #f8f9fa;
        border-bottom: 2px solid var(--primary-red);
    }

    .badge-price {
        background-color: rgba(231, 76, 60, 0.1);
        color: var(--primary-red);
        font-weight: 700;
        padding: 0.5rem 0.8rem;
        border-radius: 8px;
    }
</style>

<div class="layout" style="display: flex; height: 100vh; width: 100%; background-color: #f4f7f6;">

    @await Html.PartialAsync("~/Views/Dashboard/_Sidebar.cshtml")

    <div class="content" style="flex: 1; display: flex; flex-direction: column; height: 100%;">

        @await Html.PartialAsync("~/Views/Dashboard/_Header.cshtml")

        <div class="main-content" style="flex: 1; overflow-y: auto; padding: 2rem;">

            <div class="mb-4 text-center">
                <div style="background-color: var(--primary-red); width: 60px; height: 60px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; box-shadow: 0 4px 10px rgba(231, 76, 60, 0.3);">
                    <i class="fa-solid fa-utensils fa-2x" style="color: white;"></i>
                </div>
                <h2 style="font-weight: 800; color: var(--dark-blue); text-transform: uppercase; letter-spacing: 1px;">Gestión de la Carta</h2>
                <div style="width: 50px; height: 4px; background: var(--primary-red); margin: 0.5rem auto; border-radius: 2px;"></div>
            </div>

            <div class="d-flex justify-content-end mb-3">
                <a asp-action="RegistrarProductoCarta" class="btn btn-system-red shadow-sm" style="border-radius: 8px; padding: 0.6rem 1.2rem;">
                    <i class="fa-solid fa-circle-plus me-2"></i> Nuevo Producto
                </a>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="card-body p-4">

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-thead-custom">
                                <tr>
                                    <th class="py-3 px-3">Producto</th>
                                    <th class="py-3">Categoría</th>
                                    <th class="py-3 text-center">Precio</th>
                                    <th class="py-3 text-center">Estado</th>
                                    <th class="py-3 text-center" style="width: 200px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="px-3">
                                            <div class="fw-bold" style="color: var(--dark-blue);">@item.Nombre</div>
                                            @if (item.EsCombo)
                                            {
                                                <span class="badge bg-warning text-dark" style="font-size: 0.7rem;">COMBO</span>
                                            }
                                        </td>
                                        <td class="text-muted">
                                            <i class="fa-solid fa-tag me-1 small"></i> @item.IdCategoria
                                        </td>
                                        <td class="text-center">
                                            <span class="badge-price">S/ @item.PrecioVenta.ToString("N2")</span>
                                        </td>
                                        <td class="text-center">
                                            @if (item.Activo)
                                            {
                                                <span class="badge rounded-pill" style="background-color: rgba(39, 174, 96, 0.1); color: #27ae60; border: 1px solid #27ae60; padding: 0.5rem 1rem;">Disponible</span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-light text-muted border px-3 py-2">Inactivo</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group shadow-sm" role="group">
                                                <a asp-action="DetalleProductoCarta" asp-route-id="@item.IdProducto" class="btn btn-outline-dark btn-sm" title="Ver Detalle" style="border-color: #dee2e6;">
                                                    <i class="fa-solid fa-eye text-primary"></i>
                                                </a>
                                                <a asp-action="EdicionProductoCarta" asp-route-id="@item.IdProducto" class="btn btn-outline-dark btn-sm" title="Editar" style="border-color: #dee2e6;">
                                                    <i class="fa-solid fa-pen-to-square text-warning"></i>
                                                </a>
                                                <a asp-controller="ProductosInsumosApi" asp-action="ListadoRecetaProducto" asp-route-idProducto="@item.IdProducto" class="btn btn-outline-dark btn-sm" title="Receta" style="border-color: #dee2e6;">
                                                    <i class="fa-solid fa-mortar-pestle text-info"></i>
                                                </a>
                                                <a asp-action="DesactivarProductoCarta" asp-route-id="@item.IdProducto" class="btn btn-outline-dark btn-sm" style="border-color: #dee2e6;" onclick="return confirm('¿Desactivar producto?')">
                                                    <i class="fa-solid fa-power-off text-danger"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>