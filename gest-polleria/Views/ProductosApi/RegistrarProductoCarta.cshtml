@model appPolleria.Models.Producto

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i> Nuevo Plato / Combo</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="RegistrarProductoCarta" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre del Producto</label>
                            <input asp-for="Nombre" class="form-control shadow-sm" placeholder="Ej: 1/4 Pollo + Papas" required />
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Categoría</label>
                                <select asp-for="IdCategoria" class="form-select shadow-sm"
                                        asp-items="@(new SelectList(ViewBag.Categorias, "IdCategoria", "Nombre"))">
                                    <option value="">-- Seleccione --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Precio (S/)</label>
                                <input asp-for="PrecioVenta" class="form-control shadow-sm" type="number" step="0.10" required />
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="form-check form-switch mt-2">
                                    <input asp-for="EsCombo" class="form-check-input" type="checkbox">
                                    <label class="form-check-label">¿Es un Combo?</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check form-switch mt-2">
                                    <input asp-for="Activo" class="form-check-input" type="checkbox" checked>
                                    <label class="form-check-label">Producto Activo</label>
                                </div>
                            </div>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg shadow">Guardar en la Carta</button>
                            <a asp-action="ListadoProductosCarta" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>