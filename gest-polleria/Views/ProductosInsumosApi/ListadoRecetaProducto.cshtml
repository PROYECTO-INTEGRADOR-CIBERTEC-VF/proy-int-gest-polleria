@model IEnumerable<appPolleria.Models.ProductoInsumo>

@{
    ViewData["Title"] = "Composición del Plato";
    ViewBag.Titulo = "Gestión de Recetas";
}

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
        --bg-light: #f4f7f6;
    }

    .btn-system-red {
        background-color: var(--primary-red);
        color: white;
        border: none;
        transition: all 0.3s;
        font-weight: 600;
        border-radius: 8px;
    }

        .btn-system-red:hover {
            background-color: #c0392b;
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(231, 76, 60, 0.2);
        }

    .table-thead-custom {
        background-color: #f8f9fa;
        border-bottom: 2px solid var(--primary-red);
    }

    .badge-quantity {
        background-color: rgba(47, 62, 80, 0.1);
        color: var(--dark-blue);
        font-weight: 700;
        padding: 0.5rem 0.8rem;
        border-radius: 8px;
    }
</style>

<div class="layout" style="display: flex; height: 100vh; width: 100%; background-color: var(--bg-light);">

    @await Html.PartialAsync("~/Views/Dashboard/_Sidebar.cshtml")

    <div class="content" style="flex: 1; display: flex; flex-direction: column; height: 100%;">

        @await Html.PartialAsync("~/Views/Dashboard/_Header.cshtml")

        <div class="main-content" style="flex: 1; overflow-y: auto; padding: 2rem;">

            <div class="mb-4 text-center">
                <div style="background-color: var(--primary-red); width: 60px; height: 60px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; box-shadow: 0 4px 10px rgba(231, 76, 60, 0.3);">
                    <i class="fa-solid fa-mortar-pestle fa-2x" style="color: white;"></i>
                </div>
                <h2 style="font-weight: 800; color: var(--dark-blue); text-transform: uppercase; letter-spacing: 1px;">Receta del Producto</h2>
                <div style="width: 50px; height: 4px; background: var(--primary-red); margin: 0.5rem auto; border-radius: 2px;"></div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <a asp-controller="ProductosApi" asp-action="ListadoProductosCarta" class="btn btn-outline-secondary shadow-sm" style="border-radius: 8px;">
                    <i class="fa-solid fa-chevron-left me-2"></i> Volver a la Carta
                </a>
                <a asp-action="RegistrarInsumoReceta" asp-route-idProducto="@ViewBag.IdProducto" class="btn btn-system-red shadow-sm" style="padding: 0.6rem 1.2rem;">
                    <i class="fa-solid fa-circle-plus me-2"></i> Añadir Insumo
                </a>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-thead-custom">
                                <tr>
                                    <th class="py-3 px-3">Insumo</th>
                                    <th class="py-3 text-center">Cantidad Requerida</th>
                                    <th class="py-3 text-center">Unidad</th>
                                    <th class="py-3 text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="px-3">
                                                <div class="fw-bold" style="color: var(--dark-blue);">@item.Insumo</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge-quantity">@item.Cantidad.ToString("N3")</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge rounded-pill" style="background-color: rgba(231, 76, 60, 0.1); color: var(--primary-red); border: 1px solid var(--primary-red); padding: 0.4rem 0.8rem;">
                                                    @item.Abreviatura
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="EliminarInsumoReceta"
                                                   asp-route-id="@item.IdProductoInsumo"
                                                   asp-route-idProducto="@ViewBag.IdProducto"
                                                   class="btn btn-outline-danger btn-sm shadow-sm"
                                                   style="border-radius: 6px;"
                                                   onclick="return confirm('¿Retirar este insumo de la receta?')">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <i class="fa-solid fa-box-open fa-3x mb-3 d-block opacity-25"></i>
                                            No se han definido insumos para este producto aún.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>