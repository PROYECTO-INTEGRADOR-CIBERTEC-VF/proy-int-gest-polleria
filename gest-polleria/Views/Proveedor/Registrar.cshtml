@model appPolleria.Models.Proveedor

@{
    ViewData["Title"] = "Registrar Proveedor";
    ViewBag.Titulo = "Gestión de Proveedores";
}

<style>
    :root {
        --primary-red: #e74c3c;
        --dark-blue: #2f3e50;
        --bg-light: #f4f7f6;
    }

    .form-control:focus {
        border-color: var(--primary-red);
        box-shadow: 0 0 0 0.25rem rgba(231, 76, 60, 0.25);
    }

    .input-group-text {
        background-color: #ffffff;
        border-right: none;
        color: var(--primary-red);
    }

    .form-control {
        border-left: none;
        border-radius: 0 8px 8px 0;
    }
</style>

<div class="layout" style="display: flex; height: 100vh; width: 100%; background-color: var(--bg-light);">

    @await Html.PartialAsync("~/Views/Dashboard/_Sidebar.cshtml")

    <div class="content" style="flex: 1; display: flex; flex-direction: column; height: 100%;">

        @await Html.PartialAsync("~/Views/Dashboard/_Header.cshtml")

        <div class="main-content" style="flex: 1; overflow-y: auto; padding: 3rem; display: flex; justify-content: center; align-items: flex-start;">

            <div class="card shadow-lg" style="width: 100%; max-width: 600px; border: none; border-radius: 15px;">

                <div class="card-header text-white text-center" style="background-color: var(--primary-red); border-radius: 15px 15px 0 0; padding: 2rem; border: none;">
                    <i class="fa-solid fa-truck-ramp-box fa-3x mb-3"></i>
                    <h3 class="mb-0" style="font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Nuevo Proveedor</h3>
                    <div style="width: 40px; height: 3px; background: white; margin: 0.5rem auto; border-radius: 2px; opacity: 0.7;"></div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Registrar" method="post">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Ruc" class="form-label fw-bold" style="color: var(--dark-blue);">RUC</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text"><i class="fa-solid fa-address-card"></i></span>
                                    <input asp-for="Ruc" class="form-control" placeholder="10..." />
                                </div>
                                <span asp-validation-for="Ruc" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Telefono" class="form-label fw-bold" style="color: var(--dark-blue);">Teléfono</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                                    <input asp-for="Telefono" class="form-control" placeholder="999..." />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RazonSocial" class="form-label fw-bold" style="color: var(--dark-blue);">Razón Social</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text"><i class="fa-solid fa-building"></i></span>
                                <input asp-for="RazonSocial" class="form-control" placeholder="Nombre de la empresa" />
                            </div>
                            <span asp-validation-for="RazonSocial" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Direccion" class="form-label fw-bold" style="color: var(--dark-blue);">Dirección</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text"><i class="fa-solid fa-location-dot"></i></span>
                                <input asp-for="Direccion" class="form-control" placeholder="Av. Ejemplo 123" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold" style="color: var(--dark-blue);">Email</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                                    <input asp-for="Email" class="form-control" placeholder="correo@empresa.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Contacto" class="form-label fw-bold" style="color: var(--dark-blue);">Persona de Contacto</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text"><i class="fa-solid fa-user-tie"></i></span>
                                    <input asp-for="Contacto" class="form-control" placeholder="Nombre del contacto" />
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" style="opacity: 0.1;">

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-lg shadow" style="background-color: var(--primary-red); color: white; border: none; border-radius: 12px; font-weight: 700; padding: 0.8rem;">
                                <i class="fa-solid fa-floppy-disk me-2"></i> REGISTRAR PROVEEDOR
                            </button>
                            <a asp-action="Proveedor" class="btn btn-link text-decoration-none fw-bold" style="color: var(--dark-blue);">
                                <i class="fa-solid fa-arrow-left me-1"></i> VOLVER AL LISTADO
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}